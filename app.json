{
  "expo": {
    "name": "Ministry Tracker",
    "slug": "ministry-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "android": {
      "package": "com.bechara.ministrytracker",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "updates": {
      "enabled": false
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      "expo-location",
      "expo-notifications",
      "expo-web-browser",
      "react-native-document-scanner-plugin",
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Allow Ministry Tracker to use the microphone for speech recognition.",
          "speechRecognitionPermission": "Allow Ministry Tracker to recognize your speech."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3e7ca54c-2ac7-4356-b47a-75f77c55afd4"
      }
    },
    "owner": "kamalam"
  }
}
