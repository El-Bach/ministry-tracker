{
  "expo": {
    "name": "GovPilot",
    "slug": "ministry-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icon-fullbleed.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "bundleIdentifier": "com.bechara.govpilot",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "GovPilot uses the camera to scan and attach documents to files.",
        "NSPhotoLibraryUsageDescription": "GovPilot accesses your photo library to attach documents to files.",
        "NSPhotoLibraryAddUsageDescription": "GovPilot saves scanned documents to your photo library."
      }
    },
    "android": {
      "package": "com.bechara.govpilot",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3EC4C0"
      },
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "updates": {
      "enabled": false
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      "expo-location",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "enableJetifier": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3e7ca54c-2ac7-4356-b47a-75f77c55afd4"
      }
    },
    "owner": "kamalam"
  }
}
